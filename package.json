{
  "name": "artist-reference-collection-2",
  "version": "0.1.0",
  "description": "ARC 2 clean bootstrap",
  "main": "main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "renderer:dev": "vite --config renderer/vite.config.ts",
    "electron:dev": "npm run build:main && npm run build:preload && wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm run renderer:dev\" \"npm run electron:dev\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "private": true,
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  }
}
